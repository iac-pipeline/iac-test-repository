# Terragrunt cache
.terragrunt-cache/

# Terraform directories
.terraform/

# Terraform state files
*.tfstate
*.tfstate.*

# Terraform crash logs
crash.log

# Terraform variable files (often contain secrets)
*.tfvars
*.tfvars.json

# Terraform plan files
*.tfplan

# Lock file (optional: some teams commit this)
.terraform.lock.hcl